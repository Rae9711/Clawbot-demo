# Render: server environment variables template
# Usage:
# 1) Copy values into Render Dashboard -> Service -> Environment
# 2) Do NOT commit real secrets

# Required
NODE_ENV=production
CONNECTOR_TOKEN=CHANGE_TO_A_LONG_RANDOM_SECRET

# Render injects PORT automatically.
# Keep this line only for local simulation if needed.
# PORT=10000

# ---------- LLM backend (choose ONE option) ----------

# Option A (recommended on Render): OpenRouter (cloud API)
OLLAMA_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_PLANNER_MODEL=qwen2.5:1.5b
OLLAMA_REPORTER_MODEL=qwen2.5:1.5b
OLLAMA_STYLER_MODEL=qwen2.5:1.5b

# Option B: Together.ai (if you prefer Together)
# OLLAMA_URL=https://api.together.xyz/v1
# TOGETHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_PLANNER_MODEL=qwen2.5:1.5b
# OLLAMA_REPORTER_MODEL=qwen2.5:1.5b
# OLLAMA_STYLER_MODEL=qwen2.5:1.5b

# Option C: Self-hosted Ollama endpoint reachable from Render (advanced)
# OLLAMA_URL=https://your-ollama-endpoint.example.com
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_PLANNER_MODEL=qwen2.5:1.5b
# OLLAMA_REPORTER_MODEL=qwen2.5:1.5b
# OLLAMA_STYLER_MODEL=qwen2.5:1.5b
